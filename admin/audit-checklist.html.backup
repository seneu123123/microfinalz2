      </div>

      <div class="nav-section">
        <span class="nav-section-title">SETTINGS</span>

        <a href="#" class="nav-item">
          <i data-lucide="settings"></i>
          <span>Configuration</span>
        </a>

        <a href="#" class="nav-item">
          <i data-lucide="shield"></i>
          <span>Security</span>
        </a>

        <a href="../login.html" class="nav-item">
          <i data-lucide="log-out"></i>
          <span>Logout</span>
        </a>
      </div>
    </nav>

    <div class="sidebar-footer">
      <div class="user-profile">
        <div class="user-avatar">
          <img src="../img/profile.png" alt="User">
        </div>
        <div class="user-info">
          <span class="user-name">John Doe</span>
          <span class="user-role">Administrator</span>
        </div>
        <button class="user-menu-btn">
          <i data-lucide="more-vertical"></i>
        </button>
      </div>
    </div>
  </aside>

  <main class="main-content">
    <header class="page-header">
      <div class="header-left">
        <button class="mobile-menu-btn" id="mobileMenuBtn">
          <i data-lucide="menu"></i>
        </button>
        <div class="header-title">
          <h1>Audit Checklist Configuration</h1>
          <p>Create and manage audit checklists</p>
        </div>
      </div>
      <div class="header-right">
        <div class="search-box">
          <i data-lucide="search"></i>
          <input type="search" placeholder="Search checklists...">
        </div>
        <button class="icon-btn">
          <i data-lucide="bell"></i>
        </button>
      </div>
    </header>

    <div class="content-wrapper">
      <div class="content-grid">
        <div class="content-card" style="grid-column: 1 / -1;">
          <div class="card-header">
            <div>
              <h3 class="card-title">3.2 Audit Checklist Configuration</h3>
              <p class="card-subtitle">Create and manage audit checklists</p>
            </div>
          </div>
          <div class="card-body">
            <div id="successAlert" class="alert alert-success">
              <i data-lucide="check-circle"></i> Checklist saved successfully!
            </div>
            <div id="errorAlert" class="alert alert-error">
              <i data-lucide="alert-circle"></i> <span id="errorMessage">Please fill all required fields</span>
            </div>

            <div class="form-section">
              <h4><i data-lucide="list-checks"></i> Create New Checklist</h4>
              <form id="checklistForm" class="form-grid">
                <div class="form-group">
                  <label>Checklist ID (Auto-Generated)</label>
                  <input type="text" id="checklistId" disabled placeholder="CHK-00001">
                </div>
                <div class="form-group">
                  <label>Checklist Name <span style="color: #ef4444;">*</span></label>
                  <input type="text" id="checklistName" placeholder="Enter checklist name" required>
                </div>
                <div class="form-group">
                  <label>Audit Type <span style="color: #ef4444;">*</span></label>
                  <select id="auditType" required>
                    <option value="">Select Audit Type</option>
                    <option value="Financial">Financial Audit</option>
                    <option value="Compliance">Compliance Audit</option>
                    <option value="Operational">Operational Audit</option>
                    <option value="Performance">Performance Audit</option>
                    <option value="Vendor">Vendor Audit</option>
                    <option value="Fleet">Fleet Audit</option>
                    <option value="Document">Document Audit</option>
                  </select>
                </div>
                <div class="form-group">
                  <label>Department <span style="color: #ef4444;">*</span></label>
                  <input type="text" id="department" placeholder="Department or area" required>
                </div>
                <div class="form-group">
                  <label>Status</label>
                  <select id="status">
                    <option value="Draft">Draft</option>
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                  </select>
                </div>
                <div class="form-group form-row">
                  <label>Description <span style="color: #ef4444;">*</span></label>
                  <textarea id="description" placeholder="Describe checklist purpose and scope" required></textarea>
                </div>

                <div class="form-group form-row">
                  <label>Checklist Items <span style="color: #ef4444;">*</span></label>
                  <div id="checklistItems">
                    <div class="checklist-item">
                      <input type="checkbox" checked>
                      <input type="text" placeholder="Enter checklist item" value="Sample checklist item">
                      <button type="button" class="btn-remove-item" onclick="this.parentElement.remove()">Remove</button>
                    </div>
                  </div>
                  <button type="button" class="btn-add-item" onclick="addChecklistItem()">
                    <i data-lucide="plus"></i> Add Item
                  </button>
                </div>

                <div class="button-group">
                  <button type="submit" class="btn btn-primary">
                    <i data-lucide="save"></i> Save Checklist
                  </button>
                  <button type="reset" class="btn btn-secondary">
                    <i data-lucide="refresh-cw"></i> Clear Form
                  </button>
                </div>
              </form>
            </div>

            <div class="form-section">
              <h4><i data-lucide="list"></i> Existing Checklists</h4>
              <table class="checklist-table" id="checklistTable">
                <thead>
                  <tr>
                    <th>Checklist ID</th>
                    <th>Name</th>
                    <th>Audit Type</th>
                    <th>Department</th>
                    <th>Items Count</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="checklistTableBody">
                  <tr>
                    <td colspan="7" style="text-align: center; color: var(--text-secondary);">No checklists found</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- Edit Checklist Modal -->
  <div id="editChecklistModal" class="modal">
    <div class="modal-content">
      <div class="modal-header">
        <h2>Edit Checklist</h2>
        <button class="modal-close" id="closeEditModal">&times;</button>
      </div>
      <form id="editChecklistForm" class="modal-body">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem;">
          <div class="form-group">
            <label>Checklist ID (Read-only)</label>
            <input type="text" id="editChecklistId" disabled>
          </div>
          <div class="form-group">
            <label>Checklist Name <span style="color: #ef4444;">*</span></label>
            <input type="text" id="editChecklistName" required>
          </div>
          <div class="form-group">
            <label>Audit Type <span style="color: #ef4444;">*</span></label>
            <select id="editAuditType" required>
              <option value="">Select Audit Type</option>
              <option value="Financial">Financial Audit</option>
              <option value="Compliance">Compliance Audit</option>
              <option value="Operational">Operational Audit</option>
              <option value="Performance">Performance Audit</option>
              <option value="Vendor">Vendor Audit</option>
              <option value="Fleet">Fleet Audit</option>
              <option value="Document">Document Audit</option>
            </select>
          </div>
          <div class="form-group">
            <label>Department <span style="color: #ef4444;">*</span></label>
            <input type="text" id="editDepartment" required>
          </div>
          <div class="form-group">
            <label>Status</label>
            <select id="editStatus">
              <option value="Draft">Draft</option>
              <option value="Active">Active</option>
              <option value="Inactive">Inactive</option>
            </select>
          </div>
          <div class="form-group" style="grid-column: 1 / -1;">
            <label>Description <span style="color: #ef4444;">*</span></label>
            <textarea id="editDescription" required></textarea>
          </div>
          <div class="form-group" style="grid-column: 1 / -1;">
            <label>Checklist Items</label>
            <div id="editChecklistItems"></div>
            <button type="button" class="btn-add-item" onclick="addEditChecklistItem()">
              <i data-lucide="plus"></i> Add Item
            </button>
          </div>
        </div>
      </form>
      <div class="modal-footer">
        <button class="btn-modal-cancel" id="cancelEditBtn">Cancel</button>
        <button class="btn-modal-confirm" id="saveEditBtn">Save Changes</button>
      </div>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div id="deleteChecklistModal" class="modal">
    <div class="modal-content" style="max-width: 400px;">
      <div class="modal-header">
        <h2>Delete Checklist</h2>
        <button class="modal-close" id="closeDeleteModal">&times;</button>
      </div>
      <div class="modal-body">
        <p style="color: var(--text-primary); margin: 0;">
          Are you sure you want to delete checklist <strong id="deleteChecklistName">-</strong>?
        </p>
        <p style="color: var(--text-secondary); font-size: 0.9rem; margin: 1rem 0 0 0;">
          This action cannot be undone.
        </p>
      </div>
      <div class="modal-footer">
        <button class="btn-modal-cancel" id="cancelDeleteBtn">Cancel</button>
        <button class="btn-modal-confirm" id="confirmDeleteBtn" style="background: #ef4444;">Delete</button>
      </div>
    </div>
  </div>

  <script src="../js/dashboard.js"></script>
  <script>
    lucide.createIcons();

    // Checklist Management System
    class AuditChecklist {
      constructor() {
        this.checklists = [];
        this.apiUrl = '../api/audit-checklist.php';
        this.initializeForm();
        this.loadChecklists();
      }

      // Load checklists from API
      async loadChecklists() {
        try {
          console.log('Loading checklists from:', this.apiUrl);
          const response = await fetch(this.apiUrl, {
            method: 'GET',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            }
          });

          if (!response.ok) {
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
          }

          const result = await response.json();
          console.log('API Response:', result);

          if (result.success) {
            this.checklists = result.data || [];
            console.log('Loaded checklists:', this.checklists.length);
          } else {
            this.showError('Failed to load checklists: ' + result.message);
          }
          this.displayChecklists();
        } catch (error) {
          console.error('Load checklists error:', error);
          this.showError('Error loading checklists: ' + error.message);
        }
      }

      // Initialize form
      initializeForm() {
        const form = document.getElementById('checklistForm');
        const checklistIdInput = document.getElementById('checklistId');
        checklistIdInput.placeholder = 'Auto-generated by system';
        checklistIdInput.disabled = true;
        form.addEventListener('submit', (e) => this.handleSubmit(e));
      }

      // Validate form
      validateForm(formData) {
        const requiredFields = ['checklist_name', 'audit_type', 'department', 'description'];
        
        for (let field of requiredFields) {
          if (!formData[field] || formData[field].toString().trim() === '') {
            this.showError(`${field.replace(/_/g, ' ')} is required`);
            return false;
          }
        }

        // Validate checklist items
        const items = this.getChecklistItems();
        if (items.length === 0) {
          this.showError('At least one checklist item is required');
          return false;
        }

        return true;
      }

      // Get checklist items from form
      getChecklistItems() {
        const items = [];
        const container = document.getElementById('checklistItems');
        const itemElements = container.querySelectorAll('.checklist-item');
        
        itemElements.forEach(element => {
          const textInput = element.querySelector('input[type="text"]');
          const checkbox = element.querySelector('input[type="checkbox"]');
          if (textInput && textInput.value.trim()) {
            items.push({
              text: textInput.value.trim(),
              required: checkbox.checked
            });
          }
        });
        
        return items;
      }

      // Show success message
      showSuccess(message = 'Checklist saved successfully') {
        const alert = document.getElementById('successAlert');
        alert.classList.add('show');
        setTimeout(() => alert.classList.remove('show'), 4000);
      }

      // Show error message
      showError(message) {
        const alert = document.getElementById('errorAlert');
        document.getElementById('errorMessage').textContent = message;
        alert.classList.add('show');
        setTimeout(() => alert.classList.remove('show'), 4000);
      }

      // Handle form submission
      async handleSubmit(e) {
        e.preventDefault();
        
        const formData = {
          checklist_name: document.getElementById('checklistName').value,
          audit_type: document.getElementById('auditType').value,
          department: document.getElementById('department').value,
          description: document.getElementById('description').value,
          status: document.getElementById('status').value,
          items: JSON.stringify(this.getChecklistItems())
        };

        if (!this.validateForm(formData)) {
          return;
        }

        try {
          const response = await fetch(this.apiUrl, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(formData)
          });

          const result = await response.json();

          if (result.success) {
            this.showSuccess('Checklist saved successfully with ID: ' + result.data.checklist_id);
            document.getElementById('checklistForm').reset();
            this.resetChecklistItems();
            this.loadChecklists();
          } else {
            this.showError('Failed to save checklist: ' + result.message);
          }
        } catch (error) {
          this.showError('Error saving checklist: ' + error.message);
        }
      }

      // Reset checklist items to default
      resetChecklistItems() {
        const container = document.getElementById('checklistItems');
        container.innerHTML = `
          <div class="checklist-item">
            <input type="checkbox" checked>
            <input type="text" placeholder="Enter checklist item" value="">
            <button type="button" class="btn-remove-item" onclick="this.parentElement.remove()">Remove</button>
          </div>
        `;
        lucide.createIcons();
      }

      // Display checklists in table
      displayChecklists() {
        const tbody = document.getElementById('checklistTableBody');

        if (this.checklists.length === 0) {
          tbody.innerHTML = '<tr><td colspan="7" style="text-align: center; color: var(--text-secondary);">No checklists found</td></tr>';
          return;
        }

        tbody.innerHTML = this.checklists.map(checklist => {
          const itemsCount = checklist.items ? JSON.parse(checklist.items).length : 0;
          return `
            <tr>
              <td><strong>${checklist.checklist_id}</strong></td>
              <td>${checklist.checklist_name}</td>
              <td>${checklist.audit_type}</td>
              <td>${checklist.department}</td>
              <td>${itemsCount}</td>
              <td>
                <span class="status-badge status-${checklist.status.toLowerCase()}">
                  ${checklist.status}
                </span>
              </td>
              <td>
                <div class="action-buttons">
                  <button class="btn-action btn-edit" data-checklist-id="${checklist.checklist_id}" onclick="window.editChecklist('${checklist.checklist_id}')">
                    <i data-lucide="edit-2" class="lucide-icon"></i> Edit
                  </button>
                  <button class="btn-action btn-delete" data-checklist-id="${checklist.checklist_id}" onclick="auditChecklist.deleteChecklist(event)">
                    <i data-lucide="trash-2" class="lucide-icon"></i> Delete
                  </button>
                </div>
              </td>
            </tr>
          `;
        }).join('');

        lucide.createIcons();
      }

      // Edit checklist
      editChecklist(event) {
        event.preventDefault();
        const checklistId = event.currentTarget.getAttribute('data-checklist-id');
        const checklist = this.checklists.find(c => c.checklist_id === checklistId);

        if (!checklist) {
          this.showError('Checklist not found');
          return;
        }

        // Populate modal with checklist data
        document.getElementById('editChecklistId').value = checklist.checklist_id;
        document.getElementById('editChecklistName').value = checklist.checklist_name;
        document.getElementById('editAuditType').value = checklist.audit_type;
        document.getElementById('editDepartment').value = checklist.department;
        document.getElementById('editDescription').value = checklist.description;
        document.getElementById('editStatus').value = checklist.status;

        // Populate checklist items
        const itemsContainer = document.getElementById('editChecklistItems');
        itemsContainer.innerHTML = '';
        
        if (checklist.items) {
          const items = JSON.parse(checklist.items);
          items.forEach(item => {
            const itemElement = document.createElement('div');
            itemElement.className = 'checklist-item';
            itemElement.innerHTML = `
              <input type="checkbox" ${item.required ? 'checked' : ''}>
              <input type="text" placeholder="Enter checklist item" value="${item.text}">
              <button type="button" class="btn-remove-item" onclick="this.parentElement.remove()">Remove</button>
            `;
            itemsContainer.appendChild(itemElement);
          });
        }

        this.currentEditChecklistId = checklistId;
        document.getElementById('editChecklistModal').classList.add('show');
        lucide.createIcons();
      }

      // Save edited checklist
      async saveEditChecklist() {
        const formData = {
          checklist_id: document.getElementById('editChecklistId').value,
          checklist_name: document.getElementById('editChecklistName').value,
          audit_type: document.getElementById('editAuditType').value,
          department: document.getElementById('editDepartment').value,
          description: document.getElementById('editDescription').value,
          status: document.getElementById('editStatus').value,
          items: JSON.stringify(this.getEditChecklistItems())
        };

        if (!this.validateForm(formData)) {
          return;
        }

        try {
          const response = await fetch(this.apiUrl, {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(formData)
          });

          const result = await response.json();

          if (result.success) {
            this.showSuccess('Checklist updated successfully');
            document.getElementById('editChecklistModal').classList.remove('show');
            this.loadChecklists();
          } else {
            this.showError('Failed to update checklist: ' + result.message);
          }
        } catch (error) {
          this.showError('Error updating checklist: ' + error.message);
        }
      }

      // Get edit checklist items
      getEditChecklistItems() {
        const items = [];
        const container = document.getElementById('editChecklistItems');
        const itemElements = container.querySelectorAll('.checklist-item');
        
        itemElements.forEach(element => {
          const textInput = element.querySelector('input[type="text"]');
          const checkbox = element.querySelector('input[type="checkbox"]');
          if (textInput && textInput.value.trim()) {
            items.push({
              text: textInput.value.trim(),
              required: checkbox.checked
            });
          }
        });
        
        return items;
      }

      // Delete checklist
      deleteChecklist(event) {
        event.preventDefault();
        const checklistId = event.currentTarget.getAttribute('data-checklist-id');
        const checklist = this.checklists.find(c => c.checklist_id === checklistId);

        if (!checklist) {
          this.showError('Checklist not found');
          return;
        }

        document.getElementById('deleteChecklistName').textContent = checklist.checklist_name;
        this.currentDeleteChecklistId = checklistId;
        document.getElementById('deleteChecklistModal').classList.add('show');
      }

      // Confirm delete checklist
      async confirmDeleteChecklist() {
        const checklistId = this.currentDeleteChecklistId;

        try {
          const response = await fetch(this.apiUrl, {
            method: 'DELETE',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ checklist_id: checklistId })
          });

          const result = await response.json();

          if (result.success) {
            this.showSuccess('Checklist deleted successfully');
            document.getElementById('deleteChecklistModal').classList.remove('show');
            this.loadChecklists();
          } else {
            this.showError('Failed to delete checklist: ' + result.message);
          }
        } catch (error) {
          this.showError('Error deleting checklist: ' + error.message);
        }
      }

      // Setup modal event listeners
      setupModalListeners() {
        // Edit modal
        document.getElementById('closeEditModal').addEventListener('click', () => {
          document.getElementById('editChecklistModal').classList.remove('show');
        });

        document.getElementById('cancelEditBtn').addEventListener('click', () => {
          document.getElementById('editChecklistModal').classList.remove('show');
        });

        document.getElementById('saveEditBtn').addEventListener('click', () => {
          this.saveEditChecklist();
        });

        // Delete modal
        document.getElementById('closeDeleteModal').addEventListener('click', () => {
          document.getElementById('deleteChecklistModal').classList.remove('show');
        });

        document.getElementById('cancelDeleteBtn').addEventListener('click', () => {
          document.getElementById('deleteChecklistModal').classList.remove('show');
        });

        document.getElementById('confirmDeleteBtn').addEventListener('click', () => {
          this.confirmDeleteChecklist();
        });

        // Close modal when clicking outside
        window.addEventListener('click', (e) => {
          const editModal = document.getElementById('editChecklistModal');
          const deleteModal = document.getElementById('deleteChecklistModal');
          if (e.target === editModal) {
            editModal.classList.remove('show');
          }
          if (e.target === deleteModal) {
            deleteModal.classList.remove('show');
          }
        });
      }
    }

    // Global functions for checklist items
    function addChecklistItem() {
      const container = document.getElementById('checklistItems');
      const itemElement = document.createElement('div');
      itemElement.className = 'checklist-item';
      itemElement.innerHTML = `
        <input type="checkbox" checked>
        <input type="text" placeholder="Enter checklist item">
        <button type="button" class="btn-remove-item" onclick="this.parentElement.remove()">Remove</button>
      `;
      container.appendChild(itemElement);
      lucide.createIcons();
    }

    function addEditChecklistItem() {
      const container = document.getElementById('editChecklistItems');
      const itemElement = document.createElement('div');
      itemElement.className = 'checklist-item';
      itemElement.innerHTML = `
        <input type="checkbox" checked>
        <input type="text" placeholder="Enter checklist item">
        <button type="button" class="btn-remove-item" onclick="this.parentElement.remove()">Remove</button>
      `;
      container.appendChild(itemElement);
      lucide.createIcons();
    }

    // Initialize on page load
    let auditChecklist;
    document.addEventListener('DOMContentLoaded', () => {
      auditChecklist = new AuditChecklist();
      auditChecklist.setupModalListeners();

      // Create global function for edit button
      window.editChecklist = function (checklistId) {
        console.log('Edit checklist called with ID:', checklistId);
        if (auditChecklist && auditChecklist.editChecklist) {
          const mockEvent = {
            preventDefault: () => { },
            currentTarget: {
              getAttribute: (attr) => checklistId
            }
          };
          auditChecklist.editChecklist(mockEvent);
        } else {
          console.error('auditChecklist or editChecklist method not available');
        }
      };
    });
  </script>
</body>

</html>
