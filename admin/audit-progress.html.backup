<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Audit Progress Monitoring</title>
  <link rel="stylesheet" href="../css/dashboard.css">
  <script src="https://unpkg.com/lucide@latest"></script>
  <link rel="icon" type="image/png" href="img/logo.png">
  <style>
    /* Basic Submenu CSS to ensure it hides/shows properly if not already in your CSS */
    .submenu {
      display: none;
      flex-direction: column;
      padding-left: 2.5rem;
      background: rgba(0, 0, 0, 0.02);
    }

    .submenu.active {
      display: flex;
    }

    .submenu-item {
      padding: 0.75rem 1rem;
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 0.9rem;
      transition: color 0.2s;
    }

    .submenu-item:hover {
      color: var(--brand-green);
    }

    .chevron {
      margin-left: auto;
      transition: transform 0.3s;
    }

    .nav-item.active .chevron {
      transform: rotate(180deg);
    }

    /* Form Styles */
    .form-section {
      margin-bottom: 2rem;
      background: var(--bg-primary);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 1.5rem;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .form-section h4 {
      margin: 0 0 1rem 0;
      color: var(--text-primary);
      font-size: 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding-bottom: 0.75rem;
      border-bottom: 2px solid var(--border-color);
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1.5rem;
    }

    .form-group {
      display: flex;
      flex-direction: column;
    }

    .form-group label {
      margin-bottom: 0.5rem;
      color: var(--text-primary);
      font-weight: 500;
      font-size: 0.9rem;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
      padding: 0.75rem;
      border: 1px solid var(--border-color);
      border-radius: 6px;
      font-size: 0.9rem;
      font-family: inherit;
      background: var(--bg-primary);
      color: var(--text-primary);
      transition: border-color 0.2s;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--brand-green);
      box-shadow: 0 0 0 3px rgba(44, 160, 120, 0.1);
    }

    .form-group textarea {
      resize: vertical;
      min-height: 80px;
    }

    .form-row {
      grid-column: 1 / -1;
    }

    .button-group {
      display: flex;
      gap: 1rem;
      margin-top: 2rem;
      grid-column: 1 / -1;
      padding-top: 1rem;
      border-top: 1px solid var(--border-color);
    }

    .btn {
      padding: 0.75rem 1.5rem;
      border: none;
      border-radius: 6px;
      font-size: 0.9rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .btn-primary {
      background: var(--brand-green);
      color: white;
    }

    .btn-primary:hover {
      background: #1d8659;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(44, 160, 120, 0.3);
    }

    .btn-secondary {
      background: var(--bg-secondary);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
    }

    .btn-secondary:hover {
      background: var(--border-color);
    }

    .progress-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1.5rem;
      font-size: 0.85rem;
      background: var(--bg-primary);
      border-radius: 8px;
      overflow: hidden;
      border: 1px solid var(--border-color);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .progress-table thead {
      background: var(--bg-secondary);
      border-bottom: 2px solid var(--border-color);
    }

    .progress-table th {
      padding: 0.75rem;
      text-align: left;
      font-weight: 600;
      color: var(--text-primary);
    }

    .progress-table td {
      padding: 0.75rem;
      border-bottom: 1px solid var(--border-color);
      color: var(--text-primary);
    }

    .progress-table tbody tr:hover {
      background: var(--bg-secondary);
    }

    .progress-table tbody tr:last-child td {
      border-bottom: none;
    }

    .status-badge {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
    }

    .status-scheduled {
      background: rgba(59, 130, 246, 0.15);
      color: #3b82f6;
    }

    .status-in-progress {
      background: rgba(255, 193, 7, 0.15);
      color: #f59e0b;
    }

    .status-completed {
      background: rgba(44, 160, 120, 0.15);
      color: var(--brand-green);
    }

    .status-on-hold {
      background: rgba(239, 68, 68, 0.15);
      color: #ef4444;
    }

    .status-pending-review {
      background: rgba(139, 92, 246, 0.15);
      color: #8b5cf6;
    }

    .progress-bar {
      width: 100%;
      height: 8px;
      background: var(--bg-secondary);
      border-radius: 4px;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      background: var(--brand-green);
      border-radius: 4px;
      transition: width 0.3s ease;
    }

    .alert {
      padding: 1rem;
      border-radius: 6px;
      margin-bottom: 1rem;
      display: none;
    }

    .alert.show {
      display: block;
    }

    .alert-success {
      background: rgba(44, 160, 120, 0.1);
      color: var(--brand-green);
      border: 1px solid var(--brand-green);
    }

    .alert-error {
      background: rgba(239, 68, 68, 0.1);
      color: #ef4444;
      border: 1px solid #ef4444;
    }

    .action-buttons {
      display: flex;
      gap: 0.5rem;
      align-items: center;
      flex-wrap: wrap;
    }

    .btn-action {
      padding: 0.4rem 0.8rem;
      border: none;
      border-radius: 4px;
      font-size: 0.8rem;
      cursor: pointer;
      transition: all 0.2s;
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
    }

    .btn-update {
      background: rgba(59, 130, 246, 0.1);
      color: #3b82f6;
      border: 1px solid #3b82f6;
    }

    .btn-update:hover {
      background: #3b82f6;
      color: white;
    }

    .btn-upload {
      background: rgba(44, 160, 120, 0.1);
      color: var(--brand-green);
      border: 1px solid var(--brand-green);
    }

    .btn-upload:hover {
      background: var(--brand-green);
      color: white;
    }

    .btn-view {
      background: rgba(139, 92, 246, 0.1);
      color: #8b5cf6;
      border: 1px solid #8b5cf6;
    }

    .btn-view:hover {
      background: #8b5cf6;
      color: white;
    }

    .modal {
      display: none;
      position: fixed;
      z-index: 1000;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.5);
      animation: fadeIn 0.3s;
    }

    .modal.show {
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .modal-content {
      background: #ffffff;
      border-radius: 8px;
      width: 90%;
      max-width: 600px;
      max-height: 80vh;
      overflow-y: auto;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
      animation: slideIn 0.3s;
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    @keyframes slideIn {
      from { transform: translateY(-50px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }

    .modal-header {
      padding: 1.5rem;
      border-bottom: 1px solid var(--border-color);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .modal-header h2 {
      margin: 0;
      color: var(--text-primary);
    }

    .modal-close {
      background: none;
      border: none;
      font-size: 1.5rem;
      color: var(--text-secondary);
      cursor: pointer;
      transition: color 0.2s;
    }

    .modal-close:hover {
      color: var(--text-primary);
    }

    .modal-body {
      padding: 1.5rem;
    }

    .modal-footer {
      padding: 1.5rem;
      border-top: 1px solid var(--border-color);
      display: flex;
      justify-content: flex-end;
      gap: 1rem;
    }

    .btn-modal-cancel {
      background: var(--bg-secondary);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.75rem 1.5rem;
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-modal-cancel:hover {
      background: var(--border-color);
    }

    .btn-modal-confirm {
      background: var(--brand-green);
      color: white;
      border: none;
      padding: 0.75rem 1.5rem;
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-modal-confirm:hover {
      background: #1d8659;
    }

    .file-upload {
      border: 2px dashed var(--border-color);
      border-radius: 8px;
      padding: 2rem;
      text-align: center;
      transition: border-color 0.3s;
    }

    .file-upload:hover {
      border-color: var(--brand-green);
    }

    .file-upload.dragover {
      border-color: var(--brand-green);
      background: rgba(44, 160, 120, 0.05);
    }

    .file-list {
      margin-top: 1rem;
    }

    .file-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.5rem;
      background: var(--bg-secondary);
      border-radius: 4px;
      margin-bottom: 0.5rem;
    }

    .file-info {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .file-remove {
      background: rgba(239, 68, 68, 0.1);
      color: #ef4444;
      border: 1px solid #ef4444;
      padding: 0.25rem 0.5rem;
      border-radius: 4px;
      font-size: 0.75rem;
      cursor: pointer;
      transition: all 0.2s;
    }

    .file-remove:hover {
      background: #ef4444;
      color: white;
    }

    .evidence-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 0.5rem;
    }

    .evidence-item {
      display: flex;
      align-items: center;
      gap: 0.25rem;
      padding: 0.25rem 0.5rem;
      background: rgba(44, 160, 120, 0.1);
      color: var(--brand-green);
      border-radius: 4px;
      font-size: 0.75rem;
    }
  </style>
</head>

<body>
  <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
    <i data-lucide="sun" class="sun-icon"></i>
    <i data-lucide="moon" class="moon-icon"></i>
  </button>

  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <div class="logo-container">
        <div class="logo-wrapper">
          <img src="../img/logo.png" alt="Logo" class="logo">
        </div>
        <div class="logo-text">
          <h2 class="app-name">Microfinance</h2>
          <span class="app-tagline">32005</span>
        </div>
      </div>
      <button class="sidebar-toggle" id="sidebarToggle">
        <i data-lucide="panel-left-close"></i>
      </button>
    </div>

    <nav class="sidebar-nav">
      <div class="nav-section">
        <span class="nav-section-title">MAIN MENU</span>

        <a href="dashboard.html" class="nav-item">
          <i data-lucide="layout-dashboard"></i>
          <span>Dashboard</span>
        </a>

        <a href="#" class="nav-item has-submenu" data-module="vendor">
          <i data-lucide="store"></i>
          <span>Vendor Portal</span>
          <i data-lucide="chevron-down" class="chevron"></i>
        </a>
        <div class="submenu" id="submenu-vendor">
          <a href="vendor-registration.html" class="submenu-item">1.1 Vendor Registration Administration</a>
          <a href="vendor-profile.html" class="submenu-item">1.2 Vendor Profile Management</a>
          <a href="vendor-accreditation.html" class="submenu-item">1.3 Vendor Accreditation & Compliance Review</a>
          <a href="vendor-contracts.html" class="submenu-item">1.4 Contract & Document Oversight</a>
          <a href="vendor-performance.html" class="submenu-item">1.5 Vendor Performance Monitoring</a>
          <a href="vendor-reports.html" class="submenu-item">1.6 Vendor Reports & Analytics</a>
        </div>

        <a href="#" class="nav-item has-submenu" data-module="vehicle">
          <i data-lucide="truck"></i>
          <span>Vehicle Reservation</span>
          <i data-lucide="chevron-down" class="chevron"></i>
        </a>
        <div class="submenu" id="submenu-vehicle">
          <a href="vehicle-inventory.html" class="submenu-item">2.1 Vehicle Inventory Administration</a>
          <a href="reservation-request.html" class="submenu-item">2.2 Reservation Request Review & Approval</a>
          <a href="driver-vehicle-assignment.html" class="submenu-item">2.3 Driver & Vehicle Assignment</a>
          <a href="reservation-schedule.html" class="submenu-item">2.4 Reservation Schedule Management</a>
          <a href="trip-log.html" class="submenu-item">2.5 Trip Log Monitoring</a>
          <a href="reservation-reporting.html" class="submenu-item">2.6 Reservation Usage Reporting</a>
