        <div class="submenu" id="submenu-document">
          <a href="document-intake.html" class="submenu-item">5.1 Document Intake & Classification</a>
          <a href="document-workflow.html" class="submenu-item">5.2 Workflow & Routing Administration</a>
          <a href="document-access.html" class="submenu-item">5.3 Access Control & Permission Management</a>
          <a href="document-tracking.html" class="submenu-item">5.4 Document Status & Version Tracking</a>
          <a href="document-archive.html" class="submenu-item">5.5 Document Archive Oversight</a>
          <a href="document-activity.html" class="submenu-item">5.6 Document Activity Reporting</a>
        </div>
      </div>

      <div class="nav-section">
        <span class="nav-section-title">SETTINGS</span>

        <a href="#" class="nav-item">
          <i data-lucide="settings"></i>
          <span>Configuration</span>
        </a>

        <a href="#" class="nav-item">
          <i data-lucide="shield"></i>
          <span>Security</span>
        </a>

        <a href="../login.html" class="nav-item">
          <i data-lucide="log-out"></i>
          <span>Logout</span>
        </a>
      </div>
    </nav>

    <div class="sidebar-footer">
      <div class="user-profile">
        <div class="user-avatar">
          <img src="../img/profile.png" alt="User">
        </div>
        <div class="user-info">
          <span class="user-name">John Doe</span>
          <span class="user-role">Administrator</span>
        </div>
        <button class="user-menu-btn">
          <i data-lucide="more-vertical"></i>
        </button>
      </div>
    </div>
  </aside>

  <main class="main-content">
    <header class="page-header">
      <div class="header-left">
        <button class="mobile-menu-btn" id="mobileMenuBtn">
          <i data-lucide="menu"></i>
        </button>
        <div class="header-title">
          <h1>Audit Schedule Administration</h1>
          <p>Manage audit schedules and assignments</p>
        </div>
      </div>
      <div class="header-right">
        <div class="search-box">
          <i data-lucide="search"></i>
          <input type="search" placeholder="Search audits...">
        </div>
        <button class="icon-btn">
          <i data-lucide="bell"></i>
        </button>
      </div>
    </header>

    <div class="content-wrapper">
      <div class="content-grid">
        <div class="content-card" style="grid-column: 1 / -1;">
          <div class="card-header">
            <div>
              <h3 class="card-title">3.1 Audit Schedule Administration</h3>
              <p class="card-subtitle">Schedule and manage audit activities</p>
            </div>
          </div>
          <div class="card-body">
            <div id="successAlert" class="alert alert-success">
              <i data-lucide="check-circle"></i> Audit scheduled successfully!
            </div>
            <div id="errorAlert" class="alert alert-error">
              <i data-lucide="alert-circle"></i> <span id="errorMessage">Please fill all required fields</span>
            </div>

            <div class="form-section">
              <h4><i data-lucide="calendar-plus"></i> Schedule New Audit</h4>
              <form id="auditForm" class="form-grid">
                <div class="form-group">
                  <label>Audit ID (Auto-Generated)</label>
                  <input type="text" id="auditId" disabled placeholder="AUD-00001">
                </div>
                <div class="form-group">
                  <label>Audit Title <span style="color: #ef4444;">*</span></label>
                  <input type="text" id="auditTitle" placeholder="Enter audit title" required>
                </div>
                <div class="form-group">
                  <label>Audit Type <span style="color: #ef4444;">*</span></label>
                  <select id="auditType" required>
                    <option value="">Select Audit Type</option>
                    <option value="Financial">Financial Audit</option>
                    <option value="Compliance">Compliance Audit</option>
                    <option value="Operational">Operational Audit</option>
                    <option value="Performance">Performance Audit</option>
                    <option value="Vendor">Vendor Audit</option>
                    <option value="Fleet">Fleet Audit</option>
                    <option value="Document">Document Audit</option>
                  </select>
                </div>
                <div class="form-group">
                  <label>Priority <span style="color: #ef4444;">*</span></label>
                  <select id="priority" required>
                    <option value="">Select Priority</option>
                    <option value="High">High</option>
                    <option value="Medium">Medium</option>
                    <option value="Low">Low</option>
                  </select>
                </div>
                <div class="form-group">
                  <label>Scheduled Date <span style="color: #ef4444;">*</span></label>
                  <input type="date" id="scheduledDate" required>
                </div>
                <div class="form-group">
                  <label>Expected Duration <span style="color: #ef4444;">*</span></label>
                  <select id="duration" required>
                    <option value="">Select Duration</option>
                    <option value="1">1 Day</option>
                    <option value="3">3 Days</option>
                    <option value="7">1 Week</option>
                    <option value="14">2 Weeks</option>
                    <option value="30">1 Month</option>
                  </select>
                </div>
                <div class="form-group">
                  <label>Lead Auditor <span style="color: #ef4444;">*</span></label>
                  <input type="text" id="leadAuditor" placeholder="Lead auditor name" required>
                </div>
                <div class="form-group">
                  <label>Department/Scope <span style="color: #ef4444;">*</span></label>
                  <input type="text" id="department" placeholder="Department or audit scope" required>
                </div>
                <div class="form-group form-row">
                  <label>Description <span style="color: #ef4444;">*</span></label>
                  <textarea id="description" placeholder="Describe audit objectives and scope" required></textarea>
                </div>
                <div class="form-group">
                  <label>Status</label>
                  <select id="status">
                    <option value="Scheduled">Scheduled</option>
                    <option value="In Progress">In Progress</option>
                    <option value="Completed">Completed</option>
                    <option value="Cancelled">Cancelled</option>
                  </select>
                </div>
                <div class="button-group">
                  <button type="submit" class="btn btn-primary">
                    <i data-lucide="save"></i> Schedule Audit
                  </button>
                  <button type="reset" class="btn btn-secondary">
                    <i data-lucide="refresh-cw"></i> Clear Form
                  </button>
                </div>
              </form>
            </div>

            <div class="form-section">
              <h4><i data-lucide="list"></i> Scheduled Audits</h4>
              <table class="audit-table" id="auditTable">
                <thead>
                  <tr>
                    <th>Audit ID</th>
                    <th>Title</th>
                    <th>Type</th>
                    <th>Scheduled Date</th>
                    <th>Lead Auditor</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="auditTableBody">
                  <tr>
                    <td colspan="8" style="text-align: center; color: var(--text-secondary);">No audits scheduled yet</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- Edit Audit Modal -->
  <div id="editAuditModal" class="modal">
    <div class="modal-content">
      <div class="modal-header">
        <h2>Edit Audit Information</h2>
        <button class="modal-close" id="closeEditModal">&times;</button>
      </div>
      <form id="editAuditForm" class="modal-body">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem;">
          <div class="form-group">
            <label>Audit ID (Read-only)</label>
            <input type="text" id="editAuditId" disabled>
          </div>
          <div class="form-group">
            <label>Audit Title <span style="color: #ef4444;">*</span></label>
            <input type="text" id="editAuditTitle" required>
          </div>
          <div class="form-group">
            <label>Audit Type <span style="color: #ef4444;">*</span></label>
            <select id="editAuditType" required>
              <option value="">Select Audit Type</option>
              <option value="Financial">Financial Audit</option>
              <option value="Compliance">Compliance Audit</option>
              <option value="Operational">Operational Audit</option>
              <option value="Performance">Performance Audit</option>
              <option value="Vendor">Vendor Audit</option>
              <option value="Fleet">Fleet Audit</option>
              <option value="Document">Document Audit</option>
            </select>
          </div>
          <div class="form-group">
            <label>Priority <span style="color: #ef4444;">*</span></label>
            <select id="editPriority" required>
              <option value="">Select Priority</option>
              <option value="High">High</option>
              <option value="Medium">Medium</option>
              <option value="Low">Low</option>
            </select>
          </div>
          <div class="form-group">
            <label>Scheduled Date <span style="color: #ef4444;">*</span></label>
            <input type="date" id="editScheduledDate" required>
          </div>
          <div class="form-group">
            <label>Expected Duration <span style="color: #ef4444;">*</span></label>
            <select id="editDuration" required>
              <option value="">Select Duration</option>
              <option value="1">1 Day</option>
              <option value="3">3 Days</option>
              <option value="7">1 Week</option>
              <option value="14">2 Weeks</option>
              <option value="30">1 Month</option>
            </select>
          </div>
          <div class="form-group">
            <label>Lead Auditor <span style="color: #ef4444;">*</span></label>
            <input type="text" id="editLeadAuditor" required>
          </div>
          <div class="form-group">
            <label>Department/Scope <span style="color: #ef4444;">*</span></label>
            <input type="text" id="editDepartment" required>
          </div>
          <div class="form-group" style="grid-column: 1 / -1;">
            <label>Description <span style="color: #ef4444;">*</span></label>
            <textarea id="editDescription" required></textarea>
          </div>
          <div class="form-group">
            <label>Status</label>
            <select id="editStatus">
              <option value="Scheduled">Scheduled</option>
              <option value="In Progress">In Progress</option>
              <option value="Completed">Completed</option>
              <option value="Cancelled">Cancelled</option>
            </select>
          </div>
        </div>
      </form>
      <div class="modal-footer">
        <button class="btn-modal-cancel" id="cancelEditBtn">Cancel</button>
        <button class="btn-modal-confirm" id="saveEditBtn">Save Changes</button>
      </div>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div id="deleteAuditModal" class="modal">
    <div class="modal-content" style="max-width: 400px;">
      <div class="modal-header">
        <h2>Delete Audit</h2>
        <button class="modal-close" id="closeDeleteModal">&times;</button>
      </div>
      <div class="modal-body">
        <p style="color: var(--text-primary); margin: 0;">
          Are you sure you want to delete audit <strong id="deleteAuditName">-</strong>?
        </p>
        <p style="color: var(--text-secondary); font-size: 0.9rem; margin: 1rem 0 0 0;">
          This action cannot be undone.
        </p>
      </div>
      <div class="modal-footer">
        <button class="btn-modal-cancel" id="cancelDeleteBtn">Cancel</button>
        <button class="btn-modal-confirm" id="confirmDeleteBtn" style="background: #ef4444;">Delete</button>
      </div>
    </div>
  </div>

  <script src="../js/dashboard.js"></script>
  <script>
    lucide.createIcons();

    // Audit Schedule Management System
    class AuditSchedule {
      constructor() {
        this.audits = [];
        this.apiUrl = '../api/audit-schedule.php';
        this.initializeForm();
        this.loadAudits();
      }

      // Load audits from API
      async loadAudits() {
        try {
          console.log('Loading audits from:', this.apiUrl);
          const response = await fetch(this.apiUrl, {
            method: 'GET',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            }
          });

          if (!response.ok) {
            throw new Error(`HTTP ${response.status}: ${response.statusText}`);
          }

          const result = await response.json();
          console.log('API Response:', result);

          if (result.success) {
            this.audits = result.data || [];
            console.log('Loaded audits:', this.audits.length);
          } else {
            this.showError('Failed to load audits: ' + result.message);
          }
          this.displayAudits();
        } catch (error) {
          console.error('Load audits error:', error);
          this.showError('Error loading audits: ' + error.message);
        }
      }

      // Initialize form
      initializeForm() {
        const form = document.getElementById('auditForm');
        const auditIdInput = document.getElementById('auditId');
        auditIdInput.placeholder = 'Auto-generated by system';
        auditIdInput.disabled = true;
        form.addEventListener('submit', (e) => this.handleSubmit(e));
      }

      // Validate form
      validateForm(formData) {
        const requiredFields = ['audit_title', 'audit_type', 'priority', 'scheduled_date', 'duration', 'lead_auditor', 'department', 'description'];
        
        for (let field of requiredFields) {
          if (!formData[field] || formData[field].toString().trim() === '') {
            this.showError(`${field.replace(/_/g, ' ')} is required`);
            return false;
          }
        }

        return true;
      }

      // Show success message
      showSuccess(message = 'Audit scheduled successfully') {
        const alert = document.getElementById('successAlert');
        alert.classList.add('show');
        setTimeout(() => alert.classList.remove('show'), 4000);
      }

      // Show error message
      showError(message) {
        const alert = document.getElementById('errorAlert');
        document.getElementById('errorMessage').textContent = message;
        alert.classList.add('show');
        setTimeout(() => alert.classList.remove('show'), 4000);
      }

      // Handle form submission
      async handleSubmit(e) {
        e.preventDefault();
        
        const formData = {
          audit_title: document.getElementById('auditTitle').value,
          audit_type: document.getElementById('auditType').value,
          priority: document.getElementById('priority').value,
          scheduled_date: document.getElementById('scheduledDate').value,
          duration: document.getElementById('duration').value,
          lead_auditor: document.getElementById('leadAuditor').value,
          department: document.getElementById('department').value,
          description: document.getElementById('description').value,
          status: document.getElementById('status').value
        };

        if (!this.validateForm(formData)) {
          return;
        }

        try {
          const response = await fetch(this.apiUrl, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(formData)
          });

          const result = await response.json();

          if (result.success) {
            this.showSuccess('Audit scheduled successfully with ID: ' + result.data.audit_id);
            document.getElementById('auditForm').reset();
            this.loadAudits();
          } else {
            this.showError('Failed to schedule audit: ' + result.message);
          }
        } catch (error) {
          this.showError('Error scheduling audit: ' + error.message);
        }
      }

      // Display audits in table
      displayAudits() {
        const tbody = document.getElementById('auditTableBody');

        if (this.audits.length === 0) {
          tbody.innerHTML = '<tr><td colspan="8" style="text-align: center; color: var(--text-secondary);">No audits scheduled yet</td></tr>';
          return;
        }

        tbody.innerHTML = this.audits.map(audit => `
          <tr>
            <td><strong>${audit.audit_id}</strong></td>
            <td>${audit.audit_title}</td>
            <td>${audit.audit_type}</td>
            <td>${audit.scheduled_date ? new Date(audit.scheduled_date).toLocaleDateString() : '-'}</td>
            <td>${audit.lead_auditor}</td>
            <td>
              <span class="status-badge priority-${audit.priority.toLowerCase()}">
                ${audit.priority}
              </span>
            </td>
            <td>
              <span class="status-badge status-${audit.status.toLowerCase().replace(' ', '-')}">
                ${audit.status}
              </span>
            </td>
            <td>
              <div class="action-buttons">
                <button class="btn-action btn-edit" data-audit-id="${audit.audit_id}" onclick="window.editAudit('${audit.audit_id}')">
                  <i data-lucide="edit-2" class="lucide-icon"></i> Edit
                </button>
                <button class="btn-action btn-delete" data-audit-id="${audit.audit_id}" onclick="auditSchedule.deleteAudit(event)">
                  <i data-lucide="trash-2" class="lucide-icon"></i> Delete
                </button>
              </div>
            </td>
          </tr>
        `).join('');

        lucide.createIcons();
      }

      // Edit audit
      editAudit(event) {
        event.preventDefault();
        const auditId = event.currentTarget.getAttribute('data-audit-id');
        const audit = this.audits.find(a => a.audit_id === auditId);

        if (!audit) {
          this.showError('Audit not found');
          return;
        }

        // Populate modal with audit data
        document.getElementById('editAuditId').value = audit.audit_id;
        document.getElementById('editAuditTitle').value = audit.audit_title;
        document.getElementById('editAuditType').value = audit.audit_type;
        document.getElementById('editPriority').value = audit.priority;
        document.getElementById('editScheduledDate').value = audit.scheduled_date;
        document.getElementById('editDuration').value = audit.duration;
        document.getElementById('editLeadAuditor').value = audit.lead_auditor;
        document.getElementById('editDepartment').value = audit.department;
        document.getElementById('editDescription').value = audit.description;
        document.getElementById('editStatus').value = audit.status;

        this.currentEditAuditId = auditId;
        document.getElementById('editAuditModal').classList.add('show');
      }

      // Save edited audit
      async saveEditAudit() {
        const formData = {
          audit_id: document.getElementById('editAuditId').value,
          audit_title: document.getElementById('editAuditTitle').value,
          audit_type: document.getElementById('editAuditType').value,
          priority: document.getElementById('editPriority').value,
          scheduled_date: document.getElementById('editScheduledDate').value,
          duration: document.getElementById('editDuration').value,
          lead_auditor: document.getElementById('editLeadAuditor').value,
          department: document.getElementById('editDepartment').value,
          description: document.getElementById('editDescription').value,
          status: document.getElementById('editStatus').value
        };

        if (!this.validateForm(formData)) {
          return;
        }

        try {
          const response = await fetch(this.apiUrl, {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(formData)
          });

          const result = await response.json();

          if (result.success) {
            this.showSuccess('Audit updated successfully');
            document.getElementById('editAuditModal').classList.remove('show');
            this.loadAudits();
          } else {
            this.showError('Failed to update audit: ' + result.message);
          }
        } catch (error) {
          this.showError('Error updating audit: ' + error.message);
        }
      }

      // Delete audit
      deleteAudit(event) {
        event.preventDefault();
        const auditId = event.currentTarget.getAttribute('data-audit-id');
        const audit = this.audits.find(a => a.audit_id === auditId);

        if (!audit) {
          this.showError('Audit not found');
          return;
        }

        document.getElementById('deleteAuditName').textContent = audit.audit_title;
        this.currentDeleteAuditId = auditId;
        document.getElementById('deleteAuditModal').classList.add('show');
      }

      // Confirm delete audit
      async confirmDeleteAudit() {
        const auditId = this.currentDeleteAuditId;

        try {
          const response = await fetch(this.apiUrl, {
            method: 'DELETE',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ audit_id: auditId })
          });

          const result = await response.json();

          if (result.success) {
            this.showSuccess('Audit deleted successfully');
            document.getElementById('deleteAuditModal').classList.remove('show');
            this.loadAudits();
          } else {
            this.showError('Failed to delete audit: ' + result.message);
          }
        } catch (error) {
          this.showError('Error deleting audit: ' + error.message);
        }
      }

      // Setup modal event listeners
      setupModalListeners() {
        // Edit modal
        document.getElementById('closeEditModal').addEventListener('click', () => {
          document.getElementById('editAuditModal').classList.remove('show');
        });

        document.getElementById('cancelEditBtn').addEventListener('click', () => {
          document.getElementById('editAuditModal').classList.remove('show');
        });

        document.getElementById('saveEditBtn').addEventListener('click', () => {
          this.saveEditAudit();
        });

        // Delete modal
        document.getElementById('closeDeleteModal').addEventListener('click', () => {
          document.getElementById('deleteAuditModal').classList.remove('show');
        });

        document.getElementById('cancelDeleteBtn').addEventListener('click', () => {
          document.getElementById('deleteAuditModal').classList.remove('show');
        });

        document.getElementById('confirmDeleteBtn').addEventListener('click', () => {
          this.confirmDeleteAudit();
        });

        // Close modal when clicking outside
        window.addEventListener('click', (e) => {
          const editModal = document.getElementById('editAuditModal');
          const deleteModal = document.getElementById('deleteAuditModal');
          if (e.target === editModal) {
            editModal.classList.remove('show');
          }
          if (e.target === deleteModal) {
            deleteModal.classList.remove('show');
          }
        });
      }
    }

    // Initialize on page load
    let auditSchedule;
    document.addEventListener('DOMContentLoaded', () => {
      auditSchedule = new AuditSchedule();
      auditSchedule.setupModalListeners();

      // Create global function for edit button
      window.editAudit = function (auditId) {
        console.log('Edit audit called with ID:', auditId);
        if (auditSchedule && auditSchedule.editAudit) {
          const mockEvent = {
            preventDefault: () => { },
            currentTarget: {
              getAttribute: (attr) => auditId
            }
          };
          auditSchedule.editAudit(mockEvent);
        } else {
          console.error('auditSchedule or editAudit method not available');
        }
      };
    });
  </script>
</body>

</html>
